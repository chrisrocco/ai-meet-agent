{
  "name": "ai-meet-agent",
  "version": "0.1.3",
  "description": "AI meeting twin — bidirectional realtime audio through Google Meet",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisrocco/ai-meet-agent.git"
  },
  "keywords": [
    "ai",
    "meeting",
    "google-meet",
    "gemini",
    "audio",
    "virtual-devices",
    "cli"
  ],
  "bin": {
    "ai-meet": "bin/ai-meet.ts"
  },
  "files": [
    "bin/",
    "src/",
    "!src/**/*.test.ts",
    "assets/",
    "LICENSE",
    "README.md",
    "config.example.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env src/index.ts",
    "start": "tsx bin/ai-meet.ts start",
    "test": "tsx --test src/**/*.test.ts",
    "test-devices": "tsx src/cli/test-devices.ts"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "commander": "^14.0.3",
    "fluent-ffmpeg": "^2.1.3",
    "tsx": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
