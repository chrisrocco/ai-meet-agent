{
  "name": "ai-meet-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ai-meet": "./bin/ai-meet.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
